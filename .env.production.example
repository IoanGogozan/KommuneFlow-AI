NODE_ENV=production

APP_DOMAIN=example.com
APP_BASE_URL=https://example.com
ACME_EMAIL=admin@example.com
DEMO_BASIC_AUTH_USER=replace-with-demo-gate-username
# Generate with: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'replace-with-demo-gate-password'
DEMO_BASIC_AUTH_HASH=replace-with-caddy-bcrypt-hash
CORS_ALLOWED_ORIGINS=https://example.com
JSON_BODY_LIMIT=1mb
FORM_BODY_LIMIT=1mb

POSTGRES_DB=kommuneflow_ai
POSTGRES_USER=kommuneflow
POSTGRES_PASSWORD=replace-with-long-random-password

JWT_SECRET=replace-with-at-least-32-random-bytes
SESSION_SECRET=replace-with-at-least-32-random-bytes
STATUS_CODE_PEPPER=replace-with-separate-long-random-status-code-pepper

LOG_LEVEL=info
DEFAULT_LOCALE=nb
SUPPORTED_LOCALES=nb,en

AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional backup encryption. Set one of these on the server when backup artifacts leave the VPS.
# BACKUP_GPG_RECIPIENT=ops-backups@example.com
# BACKUP_GPG_PASSPHRASE=replace-with-backup-passphrase
# BACKUP_KEEP_PLAINTEXT=no
