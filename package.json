{
  "name": "kommuneflow-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/dev-start.ps1",
    "dev:raw": "pnpm --parallel --filter @kommuneflow/api --filter @kommuneflow/web dev",
    "dev:start": "powershell -ExecutionPolicy Bypass -File scripts/dev-start.ps1",
    "dev:status": "powershell -ExecutionPolicy Bypass -File scripts/dev-status.ps1",
    "dev:stop": "powershell -ExecutionPolicy Bypass -File scripts/dev-stop.ps1",
    "dev:api": "pnpm --filter @kommuneflow/api start:dev",
    "dev:web": "pnpm --filter @kommuneflow/web dev",
    "build": "pnpm --recursive --if-present build",
    "lint": "pnpm --recursive --if-present lint",
    "format": "pnpm --recursive --if-present format",
    "test": "pnpm --recursive --if-present test",
    "test:all": "pnpm lint && pnpm typecheck && pnpm --filter @kommuneflow/api test:cov:ci && pnpm --filter @kommuneflow/api test:e2e:ci && pnpm --filter @kommuneflow/web test && pnpm --filter @kommuneflow/web test:e2e && pnpm test:etl",
    "test:etl": "cd apps/etl && python -m pytest",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "audit:deps": "pnpm audit --audit-level high",
    "screenshots:demo": "node scripts/capture-demo-screenshots.mjs"
  },
  "devDependencies": {
    "playwright": "1.55.1",
    "prettier": "^3.4.2",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": ">=1.19.13",
      "postcss": ">=8.5.10"
    }
  }
}
