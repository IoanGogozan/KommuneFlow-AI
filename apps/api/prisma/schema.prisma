generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TenantLanguage {
  nb
  en
}

enum UserRole {
  case_worker
  department_admin
  auditor
  super_admin
}

enum UserStatus {
  active
  disabled
}

enum CaseStatus {
  new
  triage_pending
  triaged
  in_progress
  waiting_for_citizen
  closed
  rejected
}

enum CaseCategory {
  building_case
  kindergarten_school
  health_care
  road_transport
  tax_finance
  water_waste
  general_inquiry
  unknown
}

enum CaseUrgency {
  low
  normal
  high
  urgent
}

enum AITriageStatus {
  pending
  completed
  failed
  reviewed
}

model Tenant {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  primaryLanguage TenantLanguage   @default(nb)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  departments     Department[]
  users           User[]
  citizenProfiles CitizenProfile[]
  cases           Case[]
  auditEvents     AuditEvent[]
  internalNotes   InternalNote[]
  documents       CaseDocument[]
  aiTriageResults AITriageResult[]
  aiReviews       AIReview[]

  @@map("tenants")
}

model Department {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  cases       Case[]
  suggestedAITriageResults AITriageResult[]
  approvedAIReviews        AIReview[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("departments")
}

model User {
  id                  String       @id @default(cuid())
  tenantId            String
  departmentId        String?
  email               String       @unique
  passwordHash        String
  name                String
  role                UserRole
  status              UserStatus   @default(active)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  tenant              Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department          Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignedCases       Case[]       @relation("AssignedCases")
  actorAuditEvents    AuditEvent[] @relation("ActorUserAuditEvents")
  internalNotes        InternalNote[]
  uploadedDocuments    CaseDocument[]
  aiReviews            AIReview[]

  @@index([tenantId])
  @@index([tenantId, departmentId])
  @@map("users")
}

model CitizenProfile {
  id               String       @id @default(cuid())
  tenantId         String
  name             String
  email            String
  phone            String?
  address          String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cases            Case[]
  actorAuditEvents AuditEvent[] @relation("ActorCitizenAuditEvents")

  @@index([tenantId])
  @@index([tenantId, email])
  @@map("citizen_profiles")
}

model Case {
  id                   String          @id @default(cuid())
  tenantId             String
  citizenProfileId     String
  assignedDepartmentId String?
  assignedUserId       String?
  title                String
  description          String
  category             CaseCategory    @default(unknown)
  status               CaseStatus      @default(new)
  urgency              CaseUrgency     @default(normal)
  sourceLanguage       TenantLanguage
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  closedAt             DateTime?
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  citizenProfile       CitizenProfile  @relation(fields: [citizenProfileId], references: [id], onDelete: Restrict)
  assignedDepartment   Department?     @relation(fields: [assignedDepartmentId], references: [id], onDelete: SetNull)
  assignedUser         User?           @relation("AssignedCases", fields: [assignedUserId], references: [id], onDelete: SetNull)
  internalNotes        InternalNote[]
  documents            CaseDocument[]
  aiTriageResults      AITriageResult[]
  aiReviews            AIReview[]

  @@index([tenantId])
  @@index([tenantId, assignedDepartmentId])
  @@index([tenantId, status])
  @@map("cases")
}

model CaseDocument {
  id               String   @id @default(cuid())
  tenantId         String
  caseId           String
  uploadedByUserId String
  originalFileName String
  storageKey       String   @unique
  mimeType         String
  sizeBytes        Int
  checksumSha256   String
  isSensitive      Boolean  @default(false)
  createdAt        DateTime @default(now())
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case             Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploadedBy       User     @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, caseId])
  @@index([tenantId, checksumSha256])
  @@map("case_documents")
}

model AITriageResult {
  id                    String         @id @default(cuid())
  tenantId              String
  caseId                String
  model                 String
  promptVersion         String
  suggestedCategory     CaseCategory?
  suggestedDepartmentId String?
  suggestedUrgency      CaseUrgency?
  summary               String?
  missingInformationJson Json
  confidenceScore       Float?
  reasoningSummary      String?
  rawResponseJson       Json
  status                AITriageStatus @default(pending)
  failureReason         String?
  createdAt             DateTime       @default(now())
  tenant                Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case                  Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  suggestedDepartment   Department?    @relation(fields: [suggestedDepartmentId], references: [id], onDelete: SetNull)
  reviews               AIReview[]

  @@index([tenantId])
  @@index([tenantId, caseId])
  @@index([tenantId, status])
  @@map("ai_triage_results")
}

model AIReview {
  id                      String         @id @default(cuid())
  tenantId                String
  caseId                  String
  aiTriageResultId        String
  reviewedByUserId        String
  approvedCategory        CaseCategory
  approvedDepartmentId    String?
  approvedUrgency         CaseUrgency
  reviewComment           String?
  wasAiSuggestionAccepted Boolean
  createdAt               DateTime       @default(now())
  tenant                  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case                    Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  aiTriageResult          AITriageResult @relation(fields: [aiTriageResultId], references: [id], onDelete: Cascade)
  reviewedBy              User           @relation(fields: [reviewedByUserId], references: [id], onDelete: Restrict)
  approvedDepartment      Department?    @relation(fields: [approvedDepartmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, caseId])
  @@index([tenantId, aiTriageResultId])
  @@map("ai_reviews")
}

model InternalNote {
  id        String   @id @default(cuid())
  tenantId  String
  caseId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, caseId])
  @@map("internal_notes")
}

model AuditEvent {
  id                    String          @id @default(cuid())
  tenantId              String
  actorUserId           String?
  actorCitizenProfileId String?
  actorRole             String?
  action                String
  entityType            String
  entityId              String
  ipAddress             String?
  userAgent             String?
  metadataJson          Json
  createdAt             DateTime        @default(now())
  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUser             User?           @relation("ActorUserAuditEvents", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorCitizenProfile   CitizenProfile? @relation("ActorCitizenAuditEvents", fields: [actorCitizenProfileId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@map("audit_events")
}
