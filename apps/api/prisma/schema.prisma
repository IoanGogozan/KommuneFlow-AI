generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TenantLanguage {
  nb
  en
}

enum UserRole {
  case_worker
  department_admin
  auditor
  super_admin
}

enum UserStatus {
  active
  disabled
}

enum CaseStatus {
  new
  triage_pending
  triaged
  in_progress
  waiting_for_citizen
  closed
  rejected
}

enum CaseCategory {
  building_case
  kindergarten_school
  health_care
  road_transport
  tax_finance
  water_waste
  general_inquiry
  unknown
}

enum CaseUrgency {
  low
  normal
  high
  urgent
}

enum AITriageStatus {
  pending
  completed
  failed
  reviewed
}

enum AddressValidationSource {
  kartverket
}

enum AddressValidationStatus {
  validated
  not_found
  failed
  skipped
}

enum ExternalDataImportStatus {
  started
  completed
  failed
}

enum AIObservabilityStatus {
  success
  failed
}

enum AIProviderFailureClassification {
  timeout
  provider_error
  invalid_response
  validation_failed
}

enum OperationalEventSeverity {
  info
  warning
  error
  critical
}

model Tenant {
  id                         String                       @id @default(cuid())
  name                       String
  slug                       String                       @unique
  primaryLanguage            TenantLanguage               @default(nb)
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt
  departments                Department[]
  users                      User[]
  citizenProfiles            CitizenProfile[]
  cases                      Case[]
  emailLogs                  EmailLog[]
  auditEvents                AuditEvent[]
  internalNotes              InternalNote[]
  documents                  CaseDocument[]
  caseAddresses              CaseAddress[]
  aiTriageResults            AITriageResult[]
  aiReviews                  AIReview[]
  analyticsDailySnapshots    AnalyticsDailySnapshot[]
  analyticsDepartmentDaily   AnalyticsDepartmentDaily[]
  analyticsAiQualityDaily    AnalyticsAiQualityDaily[]
  analyticsMunicipalityDaily AnalyticsMunicipalityDaily[]
  retentionPolicy            RetentionPolicy?

  @@map("tenants")
}

model Department {
  id                       String           @id @default(cuid())
  tenantId                 String
  name                     String
  slug                     String
  description              String
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  tenant                   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users                    User[]
  cases                    Case[]
  suggestedAITriageResults AITriageResult[]
  approvedAIReviews        AIReview[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("departments")
}

model User {
  id                String         @id @default(cuid())
  tenantId          String
  departmentId      String?
  email             String         @unique
  passwordHash      String
  name              String
  role              UserRole
  status            UserStatus     @default(active)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department        Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignedCases     Case[]         @relation("AssignedCases")
  actorAuditEvents  AuditEvent[]   @relation("ActorUserAuditEvents")
  internalNotes     InternalNote[]
  uploadedDocuments CaseDocument[]
  aiReviews         AIReview[]

  @@index([tenantId])
  @@index([tenantId, departmentId])
  @@map("users")
}

model CitizenProfile {
  id                String         @id @default(cuid())
  tenantId          String
  name              String
  email             String
  phone             String?
  address           String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cases             Case[]
  actorAuditEvents  AuditEvent[]   @relation("ActorCitizenAuditEvents")
  uploadedDocuments CaseDocument[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@map("citizen_profiles")
}

model Case {
  id                   String           @id @default(cuid())
  tenantId             String
  citizenProfileId     String
  assignedDepartmentId String?
  assignedUserId       String?
  caseReference        String           @unique
  statusAccessCodeHash String
  title                String
  description          String
  category             CaseCategory     @default(unknown)
  status               CaseStatus       @default(new)
  urgency              CaseUrgency      @default(normal)
  sourceLanguage       TenantLanguage
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  closedAt             DateTime?
  tenant               Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  citizenProfile       CitizenProfile   @relation(fields: [citizenProfileId], references: [id], onDelete: Restrict)
  assignedDepartment   Department?      @relation(fields: [assignedDepartmentId], references: [id], onDelete: SetNull)
  assignedUser         User?            @relation("AssignedCases", fields: [assignedUserId], references: [id], onDelete: SetNull)
  internalNotes        InternalNote[]
  documents            CaseDocument[]
  aiTriageResults      AITriageResult[]
  aiReviews            AIReview[]
  addresses            CaseAddress[]
  emailLogs            EmailLog[]

  @@index([tenantId])
  @@index([tenantId, caseReference])
  @@index([tenantId, assignedDepartmentId])
  @@index([tenantId, status])
  @@map("cases")
}

model EmailLog {
  id             String    @id @default(cuid())
  tenantId       String
  caseId         String?
  recipientEmail String
  subject        String
  bodyText       String
  template       String
  provider       String    @default("mock")
  status         String    @default("logged")
  metadataJson   Json
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case           Case?     @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, caseId])
  @@index([recipientEmail, createdAt])
  @@map("email_logs")
}

model CaseAddress {
  id                String                  @id @default(cuid())
  tenantId          String
  caseId            String
  originalInput     String
  normalizedAddress String?
  municipalityCode  String?
  municipalityName  String?
  postalCode        String?
  latitude          Float?
  longitude         Float?
  source            AddressValidationSource @default(kartverket)
  sourceReferenceId String?
  validationStatus  AddressValidationStatus
  validatedAt       DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  tenant            Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case              Case                    @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, caseId])
  @@map("case_addresses")
}

model IntegrationHealthEvent {
  id              String   @id @default(cuid())
  integrationName String
  eventType       String
  status          String
  latencyMs       Int?
  errorCode       String?
  safeMessage     String?
  metadataJson    Json
  createdAt       DateTime @default(now())

  @@index([integrationName, createdAt])
  @@index([eventType, status])
  @@map("integration_health_events")
}

model ExternalMunicipalityStatistic {
  id               String   @id @default(cuid())
  municipalityCode String
  municipalityName String?
  statisticKey     String
  statisticLabel   String
  year             Int
  value            Int
  unit             String
  source           String
  sourceDataset    String
  importedAt       DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([municipalityCode, statisticKey, year, sourceDataset])
  @@index([municipalityCode, year])
  @@index([statisticKey, year])
  @@map("external_municipality_statistics")
}

model ExternalDataImportRun {
  id              String                   @id @default(cuid())
  source          String
  dataset         String
  status          ExternalDataImportStatus
  startedAt       DateTime                 @default(now())
  completedAt     DateTime?
  recordsImported Int                      @default(0)
  errorMessage    String?
  metadataJson    Json
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([source, dataset, startedAt])
  @@index([status])
  @@map("external_data_import_runs")
}

model MaintenanceRun {
  id           String    @id @default(cuid())
  type         String
  status       String
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  safeMessage  String?
  metadataJson Json
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([type, startedAt])
  @@index([status])
  @@map("maintenance_runs")
}

model OperationalEvent {
  id           String                   @id @default(cuid())
  tenantId     String?
  userId       String?
  eventType    String
  severity     OperationalEventSeverity
  source       String
  requestId    String?
  safeMessage  String?
  metadataJson Json
  createdAt    DateTime                 @default(now())

  @@index([eventType, createdAt])
  @@index([severity, createdAt])
  @@index([tenantId, createdAt])
  @@map("operational_events")
}

model AIObservabilityEvent {
  id                    String                           @id @default(cuid())
  tenantId              String
  caseId                String
  aiTriageResultId      String?
  model                 String
  promptVersion         String
  durationMs            Int
  status                AIObservabilityStatus
  failureClassification AIProviderFailureClassification?
  failureReason         String?
  tokenEstimate         Int?
  costEstimateCents     Float?
  metadataJson          Json
  createdAt             DateTime                         @default(now())

  @@index([tenantId, createdAt])
  @@index([caseId])
  @@index([status, createdAt])
  @@index([failureClassification])
  @@map("ai_observability_events")
}

model CaseDocument {
  id                         String          @id @default(cuid())
  tenantId                   String
  caseId                     String
  uploadedByUserId           String?
  uploadedByCitizenProfileId String?
  originalFileName           String
  storageKey                 String          @unique
  mimeType                   String
  sizeBytes                  Int
  checksumSha256             String
  isSensitive                Boolean         @default(false)
  createdAt                  DateTime        @default(now())
  deletedAt                  DateTime?
  tenant                     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case                       Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploadedBy                 User?           @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  uploadedByCitizenProfile   CitizenProfile? @relation(fields: [uploadedByCitizenProfileId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, caseId])
  @@index([tenantId, uploadedByCitizenProfileId])
  @@index([tenantId, checksumSha256])
  @@map("case_documents")
}

model AITriageResult {
  id                     String         @id @default(cuid())
  tenantId               String
  caseId                 String
  model                  String
  promptVersion          String
  suggestedCategory      CaseCategory?
  suggestedDepartmentId  String?
  suggestedUrgency       CaseUrgency?
  summary                String?
  missingInformationJson Json
  confidenceScore        Float?
  reasoningSummary       String?
  rawResponseJson        Json
  status                 AITriageStatus @default(pending)
  failureReason          String?
  createdAt              DateTime       @default(now())
  tenant                 Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case                   Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  suggestedDepartment    Department?    @relation(fields: [suggestedDepartmentId], references: [id], onDelete: SetNull)
  reviews                AIReview[]

  @@index([tenantId])
  @@index([tenantId, caseId])
  @@index([tenantId, status])
  @@map("ai_triage_results")
}

model AIReview {
  id                      String         @id @default(cuid())
  tenantId                String
  caseId                  String
  aiTriageResultId        String
  reviewedByUserId        String
  approvedCategory        CaseCategory
  approvedDepartmentId    String?
  approvedUrgency         CaseUrgency
  reviewComment           String?
  wasAiSuggestionAccepted Boolean
  createdAt               DateTime       @default(now())
  tenant                  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case                    Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  aiTriageResult          AITriageResult @relation(fields: [aiTriageResultId], references: [id], onDelete: Cascade)
  reviewedBy              User           @relation(fields: [reviewedByUserId], references: [id], onDelete: Restrict)
  approvedDepartment      Department?    @relation(fields: [approvedDepartmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, caseId])
  @@index([tenantId, aiTriageResultId])
  @@map("ai_reviews")
}

model InternalNote {
  id        String   @id @default(cuid())
  tenantId  String
  caseId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, caseId])
  @@map("internal_notes")
}

model AuditEvent {
  id                    String          @id @default(cuid())
  tenantId              String
  actorUserId           String?
  actorCitizenProfileId String?
  actorRole             String?
  action                String
  entityType            String
  entityId              String
  ipAddress             String?
  userAgent             String?
  metadataJson          Json
  createdAt             DateTime        @default(now())
  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUser             User?           @relation("ActorUserAuditEvents", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorCitizenProfile   CitizenProfile? @relation("ActorCitizenAuditEvents", fields: [actorCitizenProfileId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@map("audit_events")
}

model AnalyticsDailySnapshot {
  id                          String    @id @default(cuid())
  tenantId                    String
  date                        DateTime
  totalCases                  Int
  casesByStatusJson           Json
  casesByCategoryJson         Json
  casesByDepartmentJson       Json
  aiReviewsTotal              Int
  aiCorrectionsTotal          Int
  aiCorrectionRate            Float
  averageTimeToTriageMinutes  Float?
  medianTimeToTriageMinutes   Float?
  averageTimeToCloseHours     Float?
  medianTimeToCloseHours      Float?
  casesWaitingForCitizen      Int       @default(0)
  aiTriageSuccessCount        Int       @default(0)
  aiTriageFailureCount        Int       @default(0)
  aiTriageFailureRate         Float     @default(0)
  aiSuggestionsAccepted       Int       @default(0)
  aiSuggestionAcceptanceRate  Float     @default(0)
  estimatedManualMinutesSaved Int       @default(0)
  municipalityPopulation      Int?
  municipalityPopulationYear  Int?
  casesPer1000Inhabitants     Float?
  ssbDataStatus               String    @default("missing")
  ssbImportedAt               DateTime?
  analyticsRebuiltAt          DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  tenant                      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId, date])
  @@map("analytics_daily_snapshots")
}

model AnalyticsDepartmentDaily {
  id                         String   @id @default(cuid())
  tenantId                   String
  date                       DateTime
  departmentId               String?
  departmentName             String
  caseCount                  Int
  averageTimeToTriageMinutes Float?
  averageTimeToCloseHours    Float?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  tenant                     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date, departmentName])
  @@index([tenantId, date])
  @@map("analytics_department_daily")
}

model AnalyticsAiQualityDaily {
  id                    String   @id @default(cuid())
  tenantId              String
  date                  DateTime
  aiReviewsTotal        Int
  aiSuggestionsAccepted Int
  aiCorrectionsTotal    Int
  aiAcceptanceRate      Float
  aiCorrectionRate      Float
  aiTriageSuccessCount  Int
  aiTriageFailureCount  Int
  aiTriageFailureRate   Float
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId, date])
  @@map("analytics_ai_quality_daily")
}

model AnalyticsMunicipalityDaily {
  id                      String    @id @default(cuid())
  tenantId                String
  date                    DateTime
  municipalityCode        String
  municipalityName        String?
  caseCount               Int
  population              Int?
  populationYear          Int?
  casesPer1000Inhabitants Float?
  ssbImportedAt           DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  tenant                  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date, municipalityCode])
  @@index([tenantId, date])
  @@index([municipalityCode, date])
  @@map("analytics_municipality_daily")
}

model RetentionPolicy {
  id                           String   @id @default(cuid())
  tenantId                     String   @unique
  closedCaseRetentionDays      Int      @default(2555)
  deletedDocumentRetentionDays Int      @default(90)
  auditEventRetentionDays      Int      @default(2555)
  analyticsRetentionDays       Int      @default(1095)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  tenant                       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("retention_policies")
}
